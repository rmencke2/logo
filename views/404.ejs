<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Page Not Found', description: 'The page you are looking for does not exist.' }) %>
  <link rel="canonical" href="https://www.influzer.ai" />
  <style>
    .error-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 60vh;
      text-align: center;
      padding: 2rem;
    }
    .error-page h1 {
      font-size: 4rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #1a1a2e;
    }
    .error-page p {
      font-size: 1.15rem;
      color: #555;
      margin-bottom: 2rem;
      max-width: 480px;
    }
    .error-page .back-link {
      display: inline-block;
      padding: 0.75rem 2rem;
      background: #4f46e5;
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 500;
      transition: background 0.2s;
    }
    .error-page .back-link:hover { background: #4338ca; }
    .error-nav { display: flex; gap: 1.5rem; margin-top: 1.5rem; flex-wrap: wrap; justify-content: center; }
    .error-nav a { color: #4f46e5; text-decoration: none; font-weight: 500; }
    .error-nav a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="error-page">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="back-link">Back to Home</a>
    <div class="error-nav">
      <a href="/insights">Insights</a>
      <a href="/mcp">MCP Directory</a>
      <a href="/video-converter">Video Converter</a>
      <a href="/meme-generator">Meme Generator</a>
    </div>
  </main>
  <%- include('partials/footer-loader') %>
</body>
</html>
