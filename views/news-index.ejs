<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>Briefs - Influzer.ai</title>
    <meta name="description" content="Short Influzer-written MCP ecosystem briefs — fast reads on connectors, IDE tooling, enterprise auth, and catalog moves." />
    <link rel="canonical" href="https://www.influzer.ai/news" />
    <%- include('partials/seo-social', {
      ogTitle: 'MCP Briefs - Influzer.ai',
      ogDescription: 'Short Influzer-written MCP ecosystem briefs — fast reads on connectors, IDE tooling, and catalog moves.',
      ogUrl: 'https://www.influzer.ai/news',
      ogType: 'website',
    }) %>
    <%- include('partials/favicon-links') %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/home.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/briefs-page.css?v=<%= assetVersion %>" />
  </head>
  <body class="registry-page">
    <%- include('partials/home-header') %>

    <header class="briefs-hero">
      <div class="briefs-hero__inner">
        <p class="briefs-hero__eyebrow">Fast reads</p>
        <h1 class="briefs-hero__title">MCP Briefs</h1>
        <p class="briefs-hero__lead">
          Short takes written by Influzer on what changed in the MCP ecosystem. For tutorials and depth, read
          <a href="/insights">Insights</a> — our original long-form articles.
        </p>
      </div>
    </header>

    <main class="briefs-shell" id="main">
      <% if (!items || items.length === 0) { %>
        <section class="briefs-empty">
          <h2 style="margin:0 0 8px;font-size:18px;">No news briefs yet</h2>
          <p style="margin:0;">Check back soon for short MCP ecosystem notes.</p>
        </section>
      <% } else { %>
        <section class="briefs-list" aria-label="MCP news briefs">
          <% items.forEach(function(item) { %>
            <a class="briefs-card" href="/news/<%= item.slug %>">
              <div class="briefs-card__meta">
                <span class="briefs-card__badge">Brief</span>
                <span><%= item.displayDate %></span>
                <% if (item.sourceName) { %>
                  <span aria-hidden="true">·</span>
                  <span><%= item.sourceName %></span>
                <% } %>
              </div>
              <h2 class="briefs-card__title"><%= item.title %></h2>
              <p class="briefs-card__summary"><%= item.excerpt %></p>
              <span class="briefs-card__cta">Read brief →</span>
            </a>
          <% }); %>
        </section>
      <% } %>

      <%- include('partials/registry-newsletter', {
        newsletterVariant: 'band',
        newsletterSource: 'news-index',
        newsletterId: 'newsletter',
        newsletterEyebrow: 'INSIGHTS IN YOUR INBOX',
        newsletterTitle: 'Get the depth, not every brief',
        newsletterDesc: 'We email when a new original Insight publishes — always with a link back to the site.',
        newsletterSuccess: "✓ You're in — we'll email on the next Insight.",
      }) %>
    </main>

    <%- include('partials/registry-footer') %>

    <script src="/js/registry.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/home-newsletter.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
