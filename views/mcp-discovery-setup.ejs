<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>Connect Influzer MCP Discovery — Claude, ChatGPT, Cursor - Influzer.ai</title>
    <meta name="description" content="Add Influzer MCP Discovery to Claude, ChatGPT, or Cursor in minutes. Search 795+ MCP servers by tool capability from inside your AI client." />
    <link rel="canonical" href="<%= canonicalUrl %>" />
    <%- include('partials/seo-social', {
      ogTitle: 'Connect Influzer MCP Discovery — Claude, ChatGPT, Cursor',
      ogDescription: 'Official read-only MCP server to search the Influzer directory from Claude, ChatGPT, or Cursor.',
      ogUrl: canonicalUrl,
    }) %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/site-header.css" />
    <link rel="stylesheet" href="/css/mcp-directory.css" />
    <link rel="stylesheet" href="/css/mcp-discovery-promo.css" />
  </head>
  <body>
    <%- include('partials/site-header', { navPath: '/mcp' }) %>
    <script src="/js/site-header.js" defer></script>

    <main class="setup-page">
      <a class="mcp-back" href="/mcp/influzer-mcp-discovery">← Influzer MCP Discovery</a>

      <h1>Connect Influzer MCP Discovery</h1>
      <p class="setup-lead">
        Our official remote MCP server lets Claude, ChatGPT, and Cursor <strong>search the Influzer directory by capability</strong> —
        tool names, categories, setup steps, and topic guides — without opening the website.
      </p>

      <div class="setup-endpoint">
        <strong>MCP endpoint (copy exactly)</strong>
        <code id="setupEndpoint"><%= guide.endpoint %></code>
        <button type="button" class="mcp-copy" id="copyEndpoint" style="margin-top: 10px;">Copy URL</button>
      </div>

      <% guide.clients.forEach(function(client) { %>
        <section class="setup-client" id="setup-<%= client.id %>">
          <h2><%= client.name %></h2>
          <p><%= client.summary %></p>
          <ol>
            <% client.steps.forEach(function(step) { %>
              <li><%= step %></li>
            <% }); %>
          </ol>
          <% if (client.configLabel && guide.cursorConfigJson) { %>
            <p><strong><%= client.configLabel %></strong></p>
            <pre><%= guide.cursorConfigJson %></pre>
          <% } %>
          <% if (client.note) { %>
            <p class="setup-note"><%= client.note %></p>
          <% } %>
          <% if (client.docsUrl) { %>
            <p><a href="<%= client.docsUrl %>" target="_blank" rel="noopener noreferrer">Official docs →</a></p>
          <% } %>
        </section>
      <% }); %>

      <section class="setup-prompts">
        <h2>Example prompts</h2>
        <ul>
          <% guide.examplePrompts.forEach(function(prompt) { %>
            <li><em><%= prompt %></em></li>
          <% }); %>
        </ul>
      </section>

      <p style="margin-top: 32px;">
        <a href="/mcp/influzer-mcp-discovery">View directory listing</a>
        · <a href="/mcp">Browse Top 100</a>
        · <a href="/insights/what-is-model-context-protocol">What is MCP?</a>
      </p>
    </main>

    <script>
      document.getElementById('copyEndpoint').addEventListener('click', function () {
        const url = document.getElementById('setupEndpoint').textContent.trim();
        navigator.clipboard.writeText(url).then(function () {
          const btn = document.getElementById('copyEndpoint');
          btn.textContent = 'Copied';
          setTimeout(function () { btn.textContent = 'Copy URL'; }, 2000);
        });
      });
    </script>
  </body>
</html>
