<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title><%= server ? `${server.name} — MCP Server Directory - Influzer.ai` : 'Server Not Found - Influzer.ai' %></title>
    <meta name="description" content="<%= server ? server.description : 'The requested MCP server could not be found.' %>" />
    <link rel="canonical" href="<%= server ? `https://www.influzer.ai/mcp/${server.slug}` : 'https://www.influzer.ai/mcp' %>" />
    <%- include('partials/seo-social', {
      ogTitle: (server ? server.name : 'Server Not Found') + ' - Influzer.ai',
      ogDescription: server ? server.description : 'MCP server not found in the Influzer.ai directory.',
      ogUrl: server ? `https://www.influzer.ai/mcp/${server.slug}` : 'https://www.influzer.ai/mcp',
      ogType: 'website',
    }) %>
    <%- include('partials/favicon-links') %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/home.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/mcp-server-page.css?v=<%= assetVersion %>" />
    <% if (server) { %>
      <script type="application/ld+json">
        <%- JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'SoftwareApplication',
          name: server.name,
          description: server.description,
          applicationCategory: 'DeveloperApplication',
          operatingSystem: 'Web',
          url: `https://www.influzer.ai/mcp/${server.slug}`,
          featureList: (server.tools || []).slice(0, 12).map((t) => t.name),
        }) %>
      </script>
    <% } %>
  </head>
  <body class="registry-page">
    <%- include('partials/home-header') %>

    <div class="mcp-crumb">
      <a href="/mcp">← Top 100</a>
      <span class="mcp-crumb__sep">/</span>
      <a href="/mcp/all">Full directory (<%= catalogTotals ? catalogTotals.total.toLocaleString() : '…' %>)</a>
    </div>

    <% if (!server) { %>
      <main class="mcp-detail-main" style="display:block;padding:48px 32px;">
        <h1>Server not found</h1>
        <p>This MCP server is not in our directory yet.</p>
      </main>
    <% } else { %>
      <main class="mcp-detail-main">
        <div class="mcp-detail-col">
          <header class="mcp-detail-header">
            <div class="mcp-detail-icon" aria-hidden="true">
              <% if (server.logoUrl) { %>
                <img src="<%= server.logoUrl %>" alt="" width="64" height="64" loading="eager"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='grid';" />
                <span style="display:none;width:100%;height:100%;place-items:center;"><%= server.logoInitial || server.name.charAt(0) %></span>
              <% } else { %>
                <%= server.logoInitial || server.name.charAt(0).toUpperCase() %>
              <% } %>
            </div>
            <div class="mcp-detail-header__body">
              <h1><%= server.name %></h1>
              <div class="mcp-detail-badges">
                <span class="mcp-pill mcp-pill--cat"><%= server.category %></span>
                <span class="mcp-pill"><%= server.transportBadge || (server.isRemote ? 'Remote' : 'Local') %></span>
                <% if (server.official) { %><span class="mcp-pill mcp-pill--official">Official</span><% } %>
                <% if (inTop100) { %><span class="mcp-pill">Top 100</span><% } %>
                <% if (server.tools && server.tools.length) { %>
                  <span class="mcp-pill mcp-pill--mono"><%= server.tools.length %> tool<%= server.tools.length === 1 ? '' : 's' %></span>
                <% } %>
              </div>
              <p class="mcp-detail-desc"><%= server.description %></p>
              <div class="mcp-detail-actions">
                <% if (server.install_command) { %>
                  <button type="button" class="mcp-btn-primary" data-copy-install data-copy-text="<%= server.install_command %>">Install</button>
                <% } else if (server.connection_url) { %>
                  <button type="button" class="mcp-btn-primary" data-copy-install data-copy-text="<%= server.connection_url %>">Copy endpoint</button>
                <% } else if (server.github_url) { %>
                  <a class="mcp-btn-primary" href="<%= server.github_url %>" target="_blank" rel="noopener noreferrer">Install from GitHub</a>
                <% } %>
                <% if (server.github_url) { %>
                  <a class="mcp-btn-outline" href="<%= server.github_url %>" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
                <% } %>
                <% if (server.docs_url && server.docs_url !== server.github_url) { %>
                  <a class="mcp-btn-outline" href="<%= server.docs_url %>" target="_blank" rel="noopener noreferrer">Docs ↗</a>
                <% } %>
              </div>
            </div>
          </header>

          <section class="mcp-section">
            <h2>How to connect</h2>
            <div class="mcp-steps">
              <% if (server.install_command) { %>
                <div class="mcp-step">
                  <span class="mcp-step__num">1</span>
                  <div>
                    <div class="mcp-step__title">Install (Claude Code / CLI)</div>
                    <div class="mcp-step__help">Run this in your terminal, then restart your client.</div>
                    <div class="mcp-terminal">
                      <code id="mcpInstallCmd"><%= server.install_command %></code>
                      <button type="button" class="mcp-terminal__copy" data-copy-install data-copy-text="<%= server.install_command %>">Copy</button>
                    </div>
                  </div>
                </div>
                <div class="mcp-step">
                  <span class="mcp-step__num">2</span>
                  <div>
                    <div class="mcp-step__title">Verify the tools loaded</div>
                    <div class="mcp-step__help">Confirm <code class="mcp-inline-code">tools/list</code> returns the expected tools before relying on them in production.</div>
                  </div>
                </div>
              <% } else if (server.connection_url) { %>
                <div class="mcp-step">
                  <span class="mcp-step__num">1</span>
                  <div>
                    <div class="mcp-step__title">Add the remote MCP URL</div>
                    <div class="mcp-step__help">Paste this endpoint into Claude, ChatGPT, or Cursor MCP settings.</div>
                    <div class="mcp-terminal">
                      <code><%= server.connection_url %></code>
                      <button type="button" class="mcp-terminal__copy" data-copy-install data-copy-text="<%= server.connection_url %>">Copy</button>
                    </div>
                  </div>
                </div>
                <div class="mcp-step">
                  <span class="mcp-step__num">2</span>
                  <div>
                    <div class="mcp-step__title">Verify the tools loaded</div>
                    <div class="mcp-step__help">Confirm <code class="mcp-inline-code">tools/list</code> returns the expected tools before relying on them in production.</div>
                  </div>
                </div>
              <% } else if (server.setup_steps && server.setup_steps.length) { %>
                <% server.setup_steps.forEach(function(step, i) { %>
                  <div class="mcp-step">
                    <span class="mcp-step__num"><%= i + 1 %></span>
                    <div>
                      <div class="mcp-step__title"><%= step.title %></div>
                      <% if (step.text) { %>
                        <div class="mcp-terminal" style="margin-top:10px;">
                          <code><%= step.text %></code>
                        </div>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="mcp-step">
                  <span class="mcp-step__num">1</span>
                  <div>
                    <div class="mcp-step__title">Open the project docs</div>
                    <div class="mcp-step__help">
                      <% if (server.github_url) { %>
                        Follow the install steps in the <a href="<%= server.github_url %>" target="_blank" rel="noopener noreferrer">GitHub repository</a>.
                      <% } else { %>
                        Check the server documentation for client-specific setup.
                      <% } %>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          </section>

          <section class="mcp-section">
            <div class="mcp-section__head">
              <h2>Tools</h2>
              <% if (server.tools && server.tools.length) { %>
                <span class="mcp-section__count">(<%= server.tools.length %>)</span>
              <% } %>
            </div>
            <% if (server.tools && server.tools.length) { %>
              <ul class="mcp-tool-list">
                <% server.tools.forEach(function(tool) { %>
                  <li class="mcp-tool-card">
                    <code><%= tool.name %></code>
                    <p><%= tool.description || 'No description provided.' %></p>
                  </li>
                <% }); %>
              </ul>
            <% } else { %>
              <p style="color:var(--hp-muted2);font-size:14px;">
                Tool names are not listed in our registry for this server. Connect it in your MCP client to see the live tool list.
              </p>
            <% } %>
          </section>

          <% if (relatedServers && relatedServers.length) { %>
            <section class="mcp-section">
              <h2>Related servers</h2>
              <div class="mcp-related-grid">
                <% relatedServers.forEach(function(rel) { %>
                  <a class="mcp-related-card" href="/mcp/<%= rel.slug %>">
                    <span class="mcp-related-card__icon" aria-hidden="true"><%= rel.initial %></span>
                    <div style="min-width:0;">
                      <div class="mcp-related-card__name"><%= rel.name %></div>
                      <div class="mcp-related-card__desc"><%= rel.desc %></div>
                    </div>
                  </a>
                <% }); %>
              </div>
            </section>
          <% } %>
        </div>

        <aside class="mcp-aside">
          <div class="mcp-glance">
            <div class="mcp-glance__label">At a glance</div>
            <div class="mcp-glance__row">
              <span class="mcp-glance__key">Transport</span>
              <span class="mcp-glance__val"><%= server.isRemote ? 'Remote (HTTP)' : 'Local (stdio)' %></span>
            </div>
            <div class="mcp-glance__row">
              <span class="mcp-glance__key">Category</span>
              <span class="mcp-glance__val"><%= server.category %></span>
            </div>
            <div class="mcp-glance__row">
              <span class="mcp-glance__key">Tools indexed</span>
              <span class="mcp-glance__val"><%= (server.tools && server.tools.length) || 0 %></span>
            </div>
            <div class="mcp-glance__row">
              <span class="mcp-glance__key">Status</span>
              <span class="mcp-glance__val mcp-glance__val--ok">● Validated daily</span>
            </div>
          </div>

          <%- include('partials/registry-newsletter', { newsletterSource: 'mcp-server-aside', newsletterId: 'newsletter' }) %>
          <%- include('partials/registry-discovery-card', {
            discoveryPromo: typeof discoveryPromo !== 'undefined' ? discoveryPromo : null,
            discoveryCardBlurb: 'Our official MCP server finds servers like this one from inside Claude, Cursor & ChatGPT.',
          }) %>
        </aside>
      </main>
    <% } %>

    <%- include('partials/registry-footer') %>

    <script src="/js/registry.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/home-newsletter.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/mcp-server-page.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
