<%#
  Affiliate CTA for MCP server detail pages.
  Expects server.affiliate: { url, headline, description, cta, provider }
%>
<% if (server && server.affiliate && server.affiliate.url) { %>
  <aside class="mcp-affiliate" aria-label="Partner offer">
    <p class="mcp-affiliate__label">Partner offer</p>
    <h2 class="mcp-affiliate__title"><%= server.affiliate.headline %></h2>
    <% if (server.affiliate.description) { %>
      <p class="mcp-affiliate__desc"><%= server.affiliate.description %></p>
    <% } %>
    <a
      class="mcp-affiliate__btn"
      href="<%= server.affiliate.url %>"
      target="_blank"
      rel="noopener noreferrer sponsored"
    ><%= server.affiliate.cta %></a>
    <p class="mcp-affiliate__fine">Affiliate link — we may earn a commission if you sign up.</p>
  </aside>
<% } %>
