<%#
  MCP server card — logo, transport badge, category colors, tool pills.
  Server must include branding fields from attachBranding().
%>
<a
  class="mcp-card"
  href="/mcp/<%= server.slug %>"
  style="--mcp-cat-border: <%= server.categoryStyle.border %>; --mcp-cat-border-dark: <%= server.categoryStyle.borderDark %>; --mcp-cat-badge-bg: <%= server.categoryStyle.badgeBg %>; --mcp-cat-badge-text: <%= server.categoryStyle.badgeText %>; --mcp-cat-badge-bg-dark: <%= server.categoryStyle.badgeBgDark %>; --mcp-cat-badge-text-dark: <%= server.categoryStyle.badgeTextDark %>;"
>
  <div class="mcp-card-body">
    <div class="mcp-card-top">
      <%- include('mcp-server-logo', {
        logoUrl: server.logoUrl,
        logoFallbackUrl: server.logoFallbackUrl,
        logoInitial: server.logoInitial,
        categoryStyle: server.categoryStyle,
      }) %>
      <div class="mcp-card-title-wrap">
        <h2 class="mcp-card-title"><%= server.name %></h2>
        <div class="mcp-card-meta">
          <span class="mcp-badge-cat"><%= server.category %></span>
          <% if (server.stars) { %>
            <span class="mcp-badge-stars">★ <%= Number(server.stars).toLocaleString() %></span>
          <% } %>
        </div>
      </div>
      <span class="mcp-badge-transport mcp-badge-transport--<%= server.isRemote ? 'remote' : 'local' %>"><%= server.transportBadge %></span>
    </div>
    <p class="mcp-card-desc"><%= server.description %></p>
    <div class="mcp-tools">
      <% const toolLimit = typeof toolDisplayLimit !== 'undefined' ? toolDisplayLimit : 4; %>
      <% if (server.tools && server.tools.length) { %>
        <% server.tools.slice(0, toolLimit).forEach(function(tool) { %>
          <span class="mcp-tool-pill" title="<%= tool.description || tool.name %>"><%= tool.name %></span>
        <% }); %>
        <% if (server.tools.length > toolLimit) { %>
          <span class="mcp-tool-pill muted">+<%= server.tools.length - toolLimit %> more</span>
        <% } %>
      <% } else { %>
        <span class="mcp-tool-pill muted">Tools on detail page</span>
      <% } %>
    </div>
  </div>
</a>
