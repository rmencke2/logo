<%#
  Shared registry newsletter card (dark ink — same in both themes).
  Optional locals:
    newsletterVariant = 'aside' | 'inline' | 'band' (default aside)
    newsletterSource, newsletterId
    newsletterEyebrow, newsletterTitle, newsletterDesc, newsletterSuccess
    newsletterSubmitLabel
%>
<%
  const nlVariant = typeof newsletterVariant !== 'undefined' ? newsletterVariant : 'aside';
  const nlSource = typeof newsletterSource !== 'undefined' ? newsletterSource : 'registry-newsletter';
  const nlId = typeof newsletterId !== 'undefined' ? newsletterId : 'newsletter';
  const isInline = nlVariant === 'inline';
  const isBand = nlVariant === 'band';
  const eyebrow = typeof newsletterEyebrow !== 'undefined' && newsletterEyebrow
    ? newsletterEyebrow
    : (isInline ? 'GET PRACTICAL AI PLAYBOOKS WEEKLY' : isBand ? 'ONE EMAIL PER WEEK' : 'EVERY THURSDAY');
  const title = typeof newsletterTitle !== 'undefined' && newsletterTitle
    ? newsletterTitle
    : (isInline ? 'One clear email each Thursday' : isBand ? 'Get weekly executive AI insights' : 'The MCP briefing 4,200+ builders read');
  const desc = typeof newsletterDesc !== 'undefined' && newsletterDesc
    ? newsletterDesc
    : (isInline
      ? 'Actionable frameworks on AI execution, agents, and MCP. Join 4,200+ builders.'
      : isBand
        ? 'Practical frameworks you can apply immediately. Join 4,200+ leaders.'
        : 'Original analysis on MCP, agents, and what to connect next. No aggregated links.');
  const success = typeof newsletterSuccess !== 'undefined' && newsletterSuccess
    ? newsletterSuccess
    : (isBand ? "✓ You're in — first email this week." : "✓ You're in — first briefing Thursday.");
  const submitLabel = typeof newsletterSubmitLabel !== 'undefined' && newsletterSubmitLabel
    ? newsletterSubmitLabel
    : (isInline || isBand ? 'Subscribe' : 'Subscribe free');
  const formRow = isInline || isBand;
%>
<div
  class="home-nl<%= isInline ? ' home-nl--inline' : '' %><%= isBand ? ' home-nl--band' : '' %>"
  id="<%= nlId %>"
  data-newsletter-source="<%= nlSource %>"
>
  <div class="home-nl__copy">
    <div class="home-nl__eyebrow"><%= eyebrow %></div>
    <h2 class="home-nl__title"><%= title %></h2>
    <p class="home-nl__desc"><%= desc %></p>
  </div>
  <form class="home-nl__form<%= formRow ? ' home-nl__form--row' : '' %>" data-newsletter-form novalidate>
    <label class="visually-hidden" for="<%= nlId %>Email" style="position:absolute;left:-9999px;">Email address</label>
    <input
      id="<%= nlId %>Email"
      class="home-nl__input"
      type="email"
      name="email"
      placeholder="you@company.com"
      maxlength="254"
      autocomplete="email"
      required
    />
    <button type="submit" class="home-nl__submit"><%= submitLabel %></button>
    <input
      class="home-nl__hp"
      type="text"
      name="website"
      autocomplete="off"
      tabindex="-1"
      aria-hidden="true"
    />
    <p class="home-nl__status" data-newsletter-status role="status" aria-live="polite"></p>
  </form>
  <div class="home-nl__success" data-newsletter-success role="status"><%= success %></div>
  <% if (!isInline && !isBand) { %>
    <div class="home-nl__quote">
      “The only MCP roundup I actually finish.”<br />
      <cite>— Staff engineer, fintech</cite>
    </div>
  <% } %>
</div>
