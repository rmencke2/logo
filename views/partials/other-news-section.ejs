<%#
  External article discovery — "From around the web" (not original Influzer content).
  Expects: otherNews { articles, isEmpty, hasData, lastRunAt }
%>
<% if (typeof otherNews !== 'undefined' && otherNews && !otherNews.isEmpty) { %>
  <section class="home-section around-web-section" aria-labelledby="aroundWebTitle">
    <div class="home-section__head around-web-section__head">
      <div>
        <h2 class="home-section__title around-web-section__title" id="aroundWebTitle">From around the web</h2>
        <p class="around-web-section__desc">Community posts and press — not written by Influzer. For our analysis, read <a href="/insights">Insights</a>.</p>
      </div>
      <span class="around-web-updated">Updated <%= otherNews.lastRunAt ? new Date(otherNews.lastRunAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'recently' %></span>
    </div>
    <div class="around-web-list">
      <% otherNews.articles.forEach(function(article) { %>
        <article class="around-web-card">
          <div class="around-web-card__meta">
            <%- include('content-type-badge', { type: 'external' }) %>
            <span><%= article.source %></span>
            <% if (article.display_date) { %><span aria-hidden="true">·</span><time datetime="<%= article.published_at || '' %>"><%= article.display_date %></time><% } %>
            <% if (article.status === 'pinned') { %><span class="around-web-pin">Pinned</span><% } %>
          </div>
          <h3 class="around-web-card__title">
            <a href="<%= article.outbound_url %>" target="_blank" rel="noopener noreferrer"><%= article.title %><span class="visually-hidden"> (opens in new tab)</span></a>
          </h3>
          <p class="around-web-card__blurb"><%= article.editorial_blurb %></p>
          <% if (article.directory_url && article.matched_server_name) { %>
            <a class="around-web-card__directory" href="<%= article.directory_url %>">Browse <%= article.matched_server_name %> in our directory →</a>
          <% } %>
        </article>
      <% }); %>
    </div>
  </section>
<% } else if (typeof otherNews !== 'undefined' && otherNews && otherNews.hasData === false) { %>
  <section class="home-section around-web-section around-web-section--empty" aria-labelledby="aroundWebTitleEmpty">
    <div class="home-section__head">
      <h2 class="home-section__title around-web-section__title" id="aroundWebTitleEmpty">From around the web</h2>
    </div>
    <p class="around-web-empty">Fetching MCP-related stories from Dev.to, Hacker News, and more. Check back soon — or read <a href="/insights">original Insights</a> now.</p>
  </section>
<% } %>
