<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title><%= post ? `${post.title} - Influzer.ai` : 'Post Not Found - Influzer.ai' %></title>
    <meta name="description" content="<%= post ? post.excerpt : 'The requested post could not be found.' %>" />
    <link rel="canonical" href="<%= post ? `https://www.influzer.ai/insights/${post.slug}` : 'https://www.influzer.ai/insights' %>" />
    <meta property="og:type" content="<%= post ? 'article' : 'website' %>" />
    <meta property="og:site_name" content="Influzer.ai" />
    <meta property="og:title" content="<%= post ? post.title : 'Post Not Found - Influzer.ai' %>" />
    <meta property="og:description" content="<%= post ? post.excerpt : 'The requested post could not be found.' %>" />
    <meta property="og:url" content="<%= post ? `https://www.influzer.ai/insights/${post.slug}` : 'https://www.influzer.ai/insights' %>" />
    <% if (post && post.coverImage) { %>
      <meta property="og:image" content="https://www.influzer.ai<%= post.coverImage %>" />
    <% } %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= post ? post.title : 'Post Not Found - Influzer.ai' %>" />
    <meta name="twitter:description" content="<%= post ? post.excerpt : 'The requested post could not be found.' %>" />
    <% if (post && post.coverImage) { %>
      <meta name="twitter:image" content="https://www.influzer.ai<%= post.coverImage %>" />
    <% } %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css">
    <% if (post) { %>
      <script type="application/ld+json">
        <%- JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'BlogPosting',
          headline: post.title,
          description: post.excerpt,
          image: post.coverImage ? [`https://www.influzer.ai${post.coverImage}`] : [],
          datePublished: post.date,
          dateModified: post.date,
          author: {
            '@type': 'Person',
            name: 'Rasmus Mencke',
          },
          publisher: {
            '@type': 'Organization',
            name: 'Influzer.ai',
            logo: {
              '@type': 'ImageObject',
              url: 'https://www.influzer.ai/favicon.svg',
            },
          },
          mainEntityOfPage: {
            '@type': 'WebPage',
            '@id': `https://www.influzer.ai/insights/${post.slug}`,
          },
          keywords: (post.tags || []).join(', '),
          articleSection: post.category || 'General',
        }) %>
      </script>
    <% } %>
    <% if (turnstileSiteKey) { %>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <% } %>
    <style>
      .post-shell { max-width: 860px; margin: 0 auto; padding: 48px 20px 80px; }
      .post-back { font-family: var(--font-ui); margin-bottom: 20px; display: inline-block; }
      .post-meta { font-family: var(--font-ui); color: var(--color-muted); margin-bottom: 12px; font-size: .85rem; }
      .post-title { margin-bottom: 12px; }
      .post-excerpt { font-size: 1.08rem; color: var(--color-charcoal-light); margin-bottom: 20px; }
      .post-cover { width: 100%; border-radius: 14px; border: 1px solid var(--color-border); margin-bottom: 20px; }
      .post-video { width: 100%; aspect-ratio: 16/9; border: 0; border-radius: 14px; margin-bottom: 22px; }
      .post-content { font-size: 1.05rem; line-height: 1.8; }
      .post-content h2, .post-content h3 { margin-top: 1.2em; margin-bottom: .5em; }
      .post-content p { margin-bottom: .95em; }
      .post-content ul { margin: 0 0 1em 1.25em; }
      .post-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
      .post-tag { font-family: var(--font-ui); font-size: .75rem; padding: 4px 8px; border-radius: 999px; background: var(--color-terracotta-light); }
      .post-author-note { margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--color-border); color: var(--color-charcoal-light); }
      .not-found { background: var(--color-paper); border: 1px solid var(--color-border); border-radius: 16px; padding: 24px; }
      .post-growth-cta { margin-top: 26px; border: 1px solid var(--color-border); border-radius: 16px; background: var(--color-cream-dark); padding: 18px; }
      .post-growth-cta h3 { margin: 0 0 6px 0; font-family: var(--font-display); }
      .post-growth-cta p { margin: 0 0 12px 0; color: var(--color-charcoal-light); }
      .post-growth-cta-actions { display: flex; gap: 10px; flex-wrap: wrap; }
      .post-growth-cta-link { display: inline-flex; align-items: center; justify-content: center; padding: 9px 14px; border-radius: 999px; font-family: var(--font-ui); text-decoration: none; font-weight: 600; }
      .post-growth-cta-link.primary { background: var(--color-charcoal); color: #fff; }
      .post-growth-cta-link.secondary { border: 1px solid var(--color-border); color: var(--color-charcoal); background: #fff; }
      .newsletter-form { margin-top: 12px; display: grid; gap: 8px; }
      .newsletter-row { display: flex; gap: 8px; flex-wrap: wrap; }
      .newsletter-input { flex: 1; min-width: 220px; font: inherit; border: 1px solid var(--color-border); border-radius: 999px; padding: 10px 14px; }
      .newsletter-submit { border: 0; border-radius: 999px; background: var(--color-charcoal); color: #fff; padding: 10px 14px; font-family: var(--font-ui); font-weight: 600; cursor: pointer; }
      .newsletter-submit:disabled { opacity: .65; cursor: not-allowed; }
      .newsletter-hp { display: none !important; }
      .newsletter-status { font-family: var(--font-ui); font-size: .84rem; min-height: 1.1em; color: var(--color-muted); }
      .newsletter-status.error { color: #b3261e; }
      .newsletter-status.success { color: #0f6f4f; }
      .related-posts { margin-top: 30px; }
      .related-posts h2 { margin: 0 0 12px 0; font-family: var(--font-display); }
      .related-posts-grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
      .related-post-card { border: 1px solid var(--color-border); border-radius: 12px; padding: 14px; background: #fff; text-decoration: none; color: inherit; }
      .related-post-card:hover { border-color: var(--color-border-strong, #c8c8c8); }
      .related-post-date { font-family: var(--font-ui); font-size: .76rem; color: var(--color-muted); margin-bottom: 6px; }
      .related-post-title { font-family: var(--font-display); font-size: 1rem; margin: 0 0 6px 0; }
      .related-post-excerpt { margin: 0; color: var(--color-charcoal-light); font-size: .92rem; line-height: 1.5; }

      .feedback-section { margin-top: 36px; padding: 22px; border: 1px solid var(--color-border); border-radius: 16px; background: var(--color-paper); }
      .feedback-title { font-family: var(--font-display); font-size: 1.2rem; margin: 0 0 12px 0; }
      .feedback-reactions { display: flex; align-items: center; gap: 8px; flex-wrap: nowrap; margin-bottom: 12px; }
      .reaction-btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; border: 1px solid var(--color-border); background: #fff; color: var(--color-charcoal); padding: 7px 10px; border-radius: 999px; font-family: var(--font-ui); font-size: .84rem; cursor: pointer; transition: transform .1s ease, background .2s ease, border-color .2s ease; min-width: 104px; }
      .reaction-btn:hover { transform: translateY(-1px); border-color: var(--color-border-strong, #c8c8c8); }
      .reaction-btn[aria-pressed="true"] { background: var(--color-charcoal); color: #fff; border-color: var(--color-charcoal); }
      .reaction-count { font-variant-numeric: tabular-nums; font-weight: 600; }
      .reaction-helper { font-family: var(--font-ui); font-size: .76rem; color: var(--color-muted); margin-bottom: 14px; display: block; }

      .comments-block { border-top: 1px solid var(--color-border); padding-top: 18px; }
      .comments-title { font-family: var(--font-display); font-size: 1.1rem; margin: 0 0 10px 0; }
      .comment-form { display: grid; gap: 10px; margin-bottom: 18px; }
      .comment-form input, .comment-form textarea { font: inherit; padding: 10px 12px; border-radius: 10px; border: 1px solid var(--color-border); background: #fff; color: var(--color-charcoal); }
      .comment-form textarea { min-height: 96px; resize: vertical; }
      .comment-hp { display: none !important; }
      .turnstile-wrap { min-height: 65px; display: flex; align-items: center; }
      .comment-form-row { display: flex; gap: 10px; align-items: center; justify-content: space-between; }
      .comment-submit { border: 0; border-radius: 999px; background: var(--color-charcoal); color: #fff; padding: 10px 18px; font-family: var(--font-ui); font-weight: 600; cursor: pointer; }
      .comment-submit:disabled { opacity: .6; cursor: not-allowed; }
      .comment-status { font-family: var(--font-ui); font-size: .85rem; min-height: 1.1em; }
      .comment-status.error { color: #b3261e; }
      .comment-status.success { color: #0f6f4f; }

      .comment-list { display: grid; gap: 12px; }
      .comment-item { padding: 12px 14px; border: 1px solid var(--color-border); border-radius: 12px; background: #fff; }
      .comment-meta { font-family: var(--font-ui); font-size: .8rem; color: var(--color-muted); margin-bottom: 6px; display: flex; gap: 8px; flex-wrap: wrap; }
      .comment-meta strong { color: var(--color-charcoal); font-weight: 600; }
      .comment-body { line-height: 1.6; white-space: pre-wrap; }
      .comments-empty { font-family: var(--font-ui); color: var(--color-muted); font-size: .9rem; }
    </style>
  </head>
  <body>
    <div class="auth-header" id="siteHeader">
      <div class="auth-header-start">
        <button type="button" class="nav-menu-toggle" id="navMenuToggle" aria-expanded="false" aria-controls="mainSiteNav" aria-label="Open menu">
          <span class="nav-menu-toggle-bars" aria-hidden="true">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
          </span>
        </button>
        <a href="/">Influzer.ai</a>
        <nav id="mainSiteNav" class="site-nav" aria-label="Main">
          <a href="/insights">Insights</a>
          <a href="/">Logo Generator</a>
          <a href="/video-converter">AVI to MP4</a>
          <a href="/video-to-gif">Video to GIF</a>
        </nav>
      </div>
    </div>

    <main class="post-shell">
      <a class="post-back" href="/insights">← Back to Insights</a>
      <% if (!post) { %>
        <section class="not-found">
          <h1>Post not found</h1>
          <p>The article you requested is not available.</p>
        </section>
      <% } else { %>
        <article>
          <div class="post-meta"><%= post.date %></div>
          <h1 class="post-title"><%= post.title %></h1>
          <p class="post-excerpt"><%= post.excerpt %></p>
          <% if (post.tags && post.tags.length) { %>
            <div class="post-tags">
              <% if (post.category) { %>
                <span class="post-tag"><%= post.category %></span>
              <% } %>
              <% post.tags.forEach((tag) => { %>
                <span class="post-tag"><%= tag %></span>
              <% }) %>
            </div>
          <% } %>
          <% if (post.coverImage) { %>
            <img class="post-cover" src="<%= post.coverImage %>" alt="<%= post.coverImageAlt %>" />
          <% } %>
          <% if (post.videoEmbedUrl) { %>
            <iframe class="post-video" src="<%= post.videoEmbedUrl %>" title="Embedded video for <%= post.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
          <% } %>
          <section class="post-content"><%- post.contentHtml %></section>
          <section class="post-growth-cta" aria-label="Get executive AI playbooks">
            <h3>Get practical AI operating playbooks each week</h3>
            <p>Follow new frameworks on EBITDA, Rule of 40, decision systems, and AI execution for leadership teams.</p>
            <div class="post-growth-cta-actions">
              <a class="post-growth-cta-link primary" href="/insights">Read the latest insights</a>
              <a class="post-growth-cta-link secondary" href="/">Try Influzer tools</a>
            </div>
            <form class="newsletter-form" id="newsletterForm" novalidate>
              <div class="newsletter-row">
                <input class="newsletter-input" type="email" id="newsletterEmail" placeholder="Enter your work email" maxlength="254" required />
                <button class="newsletter-submit" id="newsletterSubmit" type="submit">Subscribe</button>
              </div>
              <input class="newsletter-hp" type="text" id="newsletterWebsite" autocomplete="off" tabindex="-1" aria-hidden="true" />
              <span class="newsletter-status" id="newsletterStatus" role="status" aria-live="polite"></span>
            </form>
          </section>
          <section class="post-author-note">
            <p><strong>Written by Rasmus Mencke</strong> — technology and product leader sharing practical insights on AI, leadership, and scaling teams.</p>
          </section>
          <% if (relatedPosts && relatedPosts.length) { %>
            <section class="related-posts" aria-label="Related insights">
              <h2>Related insights</h2>
              <div class="related-posts-grid">
                <% relatedPosts.forEach((relatedPost) => { %>
                  <a class="related-post-card" href="/insights/<%= relatedPost.slug %>">
                    <div class="related-post-date"><%= relatedPost.date %></div>
                    <h3 class="related-post-title"><%= relatedPost.title %></h3>
                    <p class="related-post-excerpt"><%= relatedPost.excerpt %></p>
                  </a>
                <% }) %>
              </div>
            </section>
          <% } %>

          <section class="feedback-section" data-slug="<%= post.slug %>">
            <h2 class="feedback-title">Was this useful?</h2>
            <div class="feedback-reactions" role="group" aria-label="Post reactions">
              <button type="button" class="reaction-btn" data-reaction="up" aria-pressed="false">
                <span aria-hidden="true">👍</span>
                <span class="reaction-label">Up</span>
                <span class="reaction-count" data-count="up">0</span>
              </button>
              <button type="button" class="reaction-btn" data-reaction="down" aria-pressed="false">
                <span aria-hidden="true">👎</span>
                <span class="reaction-label">Down</span>
                <span class="reaction-count" data-count="down">0</span>
              </button>
            </div>
            <span class="reaction-helper">Click again to undo.</span>

            <div class="comments-block">
              <h3 class="comments-title">Leave a comment</h3>
              <form class="comment-form" id="commentForm" novalidate>
                <input type="text" name="name" id="commentName" placeholder="Your name" maxlength="60" required />
                <textarea name="comment" id="commentBody" placeholder="Share your take, question, or feedback..." maxlength="1000" required></textarea>
                <input class="comment-hp" type="text" name="website" id="commentWebsite" autocomplete="off" tabindex="-1" aria-hidden="true" />
                <% if (turnstileSiteKey) { %>
                  <div class="turnstile-wrap">
                    <div id="commentTurnstile" class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="light"></div>
                  </div>
                <% } %>
                <div class="comment-form-row">
                  <span class="comment-status" id="commentStatus" role="status" aria-live="polite"></span>
                  <button type="submit" class="comment-submit" id="commentSubmit">Post comment</button>
                </div>
              </form>
              <div class="comment-list" id="commentList">
                <p class="comments-empty" id="commentsEmpty">Be the first to share your thoughts.</p>
              </div>
            </div>
          </section>
        </article>
      <% } %>
    </main>
    <script>
      (function () {
        const siteHeader = document.getElementById('siteHeader');
        const navMenuToggle = document.getElementById('navMenuToggle');
        const mainSiteNav = document.getElementById('mainSiteNav');
        if (!siteHeader || !navMenuToggle || !mainSiteNav) return;

        function closeMobileNav() {
          siteHeader.classList.remove('nav-open');
          navMenuToggle.setAttribute('aria-expanded', 'false');
          navMenuToggle.setAttribute('aria-label', 'Open menu');
        }

        navMenuToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = !siteHeader.classList.contains('nav-open');
          siteHeader.classList.toggle('nav-open', open);
          navMenuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          navMenuToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        });

        mainSiteNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMobileNav));
        document.addEventListener('click', (e) => {
          if (siteHeader.classList.contains('nav-open') && !siteHeader.contains(e.target)) {
            closeMobileNav();
          }
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && siteHeader.classList.contains('nav-open')) closeMobileNav();
        });
      })();
    </script>

    <script>
      (function () {
        const form = document.getElementById('newsletterForm');
        const emailEl = document.getElementById('newsletterEmail');
        const submitEl = document.getElementById('newsletterSubmit');
        const statusEl = document.getElementById('newsletterStatus');
        const hpEl = document.getElementById('newsletterWebsite');
        if (!form || !emailEl || !submitEl || !statusEl || !hpEl) return;

        function setStatus(message, type) {
          statusEl.textContent = message || '';
          statusEl.classList.remove('error', 'success');
          if (type) statusEl.classList.add(type);
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const email = String(emailEl.value || '').trim();
          const website = String(hpEl.value || '').trim();
          if (!email) {
            setStatus('Please enter your email address.', 'error');
            return;
          }
          submitEl.disabled = true;
          setStatus('Subscribing...', '');
          try {
            const response = await fetch('/api/newsletter/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ email, source: 'blog_post_cta', website }),
            });
            const data = await response.json();
            if (!response.ok) {
              setStatus(data?.error || 'Could not subscribe right now.', 'error');
            } else {
              setStatus(data?.message || 'Thanks! You are subscribed.', 'success');
              form.reset();
            }
          } catch {
            setStatus('Network error. Please try again.', 'error');
          } finally {
            submitEl.disabled = false;
          }
        });
      })();
    </script>

    <script>
      (function () {
        const section = document.querySelector('.feedback-section');
        if (!section) return;
        const slug = section.getAttribute('data-slug');
        if (!slug) return;

        const reactionButtons = section.querySelectorAll('.reaction-btn');
        const commentForm = section.querySelector('#commentForm');
        const commentName = section.querySelector('#commentName');
        const commentBody = section.querySelector('#commentBody');
        const commentStatus = section.querySelector('#commentStatus');
        const commentSubmit = section.querySelector('#commentSubmit');
        const commentList = section.querySelector('#commentList');
        const commentWebsite = section.querySelector('#commentWebsite');
        const storedNameKey = 'influzer:commenter-name';
        const hasTurnstile = Boolean(<%= JSON.stringify(Boolean(turnstileSiteKey)) %>);

        try {
          const storedName = localStorage.getItem(storedNameKey);
          if (storedName) commentName.value = storedName;
        } catch {}

        function setStatus(message, type) {
          commentStatus.textContent = message || '';
          commentStatus.classList.remove('error', 'success');
          if (type) commentStatus.classList.add(type);
        }

        function escapeHtml(str) {
          return String(str || '').replace(/[&<>"']/g, (c) => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
          }[c]));
        }

        function formatDate(iso) {
          try {
            const d = new Date(iso);
            if (Number.isNaN(d.getTime())) return '';
            return d.toLocaleString(undefined, {
              year: 'numeric', month: 'short', day: 'numeric',
              hour: '2-digit', minute: '2-digit',
            });
          } catch { return ''; }
        }

        function renderReactions(data) {
          const counts = (data && data.reactions) || { up: 0, down: 0 };
          const userReaction = data && data.userReaction;
          section.querySelectorAll('[data-count]').forEach((el) => {
            const key = el.getAttribute('data-count');
            el.textContent = counts[key] != null ? counts[key] : 0;
          });
          reactionButtons.forEach((btn) => {
            const r = btn.getAttribute('data-reaction');
            btn.setAttribute('aria-pressed', userReaction === r ? 'true' : 'false');
          });
        }

        function renderComments(comments) {
          commentList.innerHTML = '';
          if (!comments || comments.length === 0) {
            const p = document.createElement('p');
            p.className = 'comments-empty';
            p.textContent = 'Be the first to share your thoughts.';
            commentList.appendChild(p);
            return;
          }
          comments.forEach((c) => {
            const wrapper = document.createElement('div');
            wrapper.className = 'comment-item';
            wrapper.innerHTML =
              '<div class="comment-meta"><strong>' + escapeHtml(c.name) + '</strong><span>' +
              escapeHtml(formatDate(c.created_at)) + '</span></div>' +
              '<div class="comment-body">' + escapeHtml(c.comment) + '</div>';
            commentList.appendChild(wrapper);
          });
        }

        async function loadFeedback() {
          try {
            const res = await fetch('/api/blog/' + encodeURIComponent(slug) + '/feedback', {
              headers: { Accept: 'application/json' },
            });
            if (!res.ok) return;
            const data = await res.json();
            renderReactions(data);
            renderComments(data.comments);
          } catch {}
        }

        async function toggleReaction(reaction) {
          try {
            const res = await fetch('/api/blog/' + encodeURIComponent(slug) + '/reactions', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ reaction }),
            });
            if (!res.ok) return;
            const data = await res.json();
            renderReactions(data);
          } catch {}
        }

        reactionButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            toggleReaction(btn.getAttribute('data-reaction'));
          });
        });

        commentForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const name = commentName.value.trim();
          const comment = commentBody.value.trim();
          const honeypot = commentWebsite ? commentWebsite.value.trim() : '';
          if (name.length < 2 || comment.length < 2) {
            setStatus('Please add your name and a comment.', 'error');
            return;
          }
          if (honeypot) {
            setStatus('Spam check failed.', 'error');
            return;
          }
          let turnstileToken = '';
          if (hasTurnstile) {
            turnstileToken = window.turnstile && typeof window.turnstile.getResponse === 'function'
              ? window.turnstile.getResponse()
              : '';
            if (!turnstileToken) {
              setStatus('Please complete the anti-spam check.', 'error');
              return;
            }
          }
          commentSubmit.disabled = true;
          setStatus('Posting...', '');
          try {
            const res = await fetch('/api/blog/' + encodeURIComponent(slug) + '/comments', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ name, comment, turnstileToken }),
            });
            const data = await res.json();
            if (!res.ok) {
              setStatus(data && data.error ? data.error : 'Something went wrong.', 'error');
            } else {
              try { localStorage.setItem(storedNameKey, name); } catch {}
              commentBody.value = '';
              setStatus('Thanks for your comment.', 'success');
              renderComments(data.comments);
              if (hasTurnstile && window.turnstile && typeof window.turnstile.reset === 'function') {
                window.turnstile.reset();
              }
            }
          } catch {
            setStatus('Network error. Please try again.', 'error');
          } finally {
            commentSubmit.disabled = false;
          }
        });

        loadFeedback();
      })();
    </script>
  </body>
</html>
