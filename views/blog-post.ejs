<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title><%= post ? `${post.title} - Influzer.ai` : 'Post Not Found - Influzer.ai' %></title>
    <meta name="description" content="<%= post ? post.excerpt : 'The requested post could not be found.' %>" />
    <link rel="canonical" href="<%= post ? `https://www.influzer.ai/insights/${post.slug}` : 'https://www.influzer.ai/insights' %>" />
    <%- include('partials/seo-social', {
      ogTitle: post ? post.title + ' - Influzer.ai' : 'Post Not Found - Influzer.ai',
      ogDescription: post ? post.excerpt : 'The requested post could not be found.',
      ogUrl: post ? `https://www.influzer.ai/insights/${post.slug}` : 'https://www.influzer.ai/insights',
      ogImage: post && post.coverImage ? `https://www.influzer.ai${post.coverImage}` : undefined,
      ogType: post ? 'article' : 'website',
      noindex: !post,
    }) %>
    <%- include('partials/favicon-links') %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/home.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/article-page.css?v=<%= assetVersion %>" />
    <% if (post) { %>
      <script type="application/ld+json">
        <%- JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'BlogPosting',
          headline: post.title,
          description: post.excerpt,
          image: post.coverImage ? [`https://www.influzer.ai${post.coverImage}`] : [],
          datePublished: post.date,
          dateModified: post.date,
          author: { '@type': 'Person', name: 'Rasmus Mencke' },
          publisher: {
            '@type': 'Organization',
            name: 'Influzer.ai',
            logo: { '@type': 'ImageObject', url: 'https://www.influzer.ai/favicon.svg' },
          },
          mainEntityOfPage: {
            '@type': 'WebPage',
            '@id': `https://www.influzer.ai/insights/${post.slug}`,
          },
          keywords: (post.tags || []).join(', '),
          articleSection: post.category || 'General',
        }) %>
      </script>
    <% } %>
    <% if (turnstileSiteKey) { %>
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <% } %>
  </head>
  <body class="registry-page">
    <%- include('partials/home-header') %>

    <div class="article-back-wrap">
      <a class="article-back" href="/insights">← Back to Insights</a>
    </div>

    <% if (!post) { %>
      <main style="max-width:760px;margin:0 auto;padding:32px;">
        <h1>Post not found</h1>
        <p>The article you requested is not available.</p>
      </main>
    <% } else { %>
      <header class="article-header">
        <div class="article-meta-row">
          <span class="article-badge">ORIGINAL</span>
          <span class="article-meta"><%= post.date %><% if (post.category) { %> · <%= post.category %><% } %></span>
        </div>
        <h1><%= post.title %></h1>
        <p class="article-deck"><%= post.excerpt %></p>
        <% if (post.tags && post.tags.length) { %>
          <div class="article-tags">
            <% post.tags.forEach(function(tag) { %>
              <span class="article-tag"><%= tag %></span>
            <% }); %>
          </div>
        <% } %>
        <div class="article-byline">
          <span class="article-avatar" aria-hidden="true">RM</span>
          <div style="flex:1;min-width:0;">
            <div class="article-byline__name">Rasmus Mencke</div>
            <div class="article-byline__sub">Technology &amp; product leader · <%= post.readMinutes %> min read</div>
          </div>
          <button type="button" class="article-share" id="articleShareBtn">Share</button>
        </div>
      </header>

      <% if (post.coverImage) { %>
        <div class="article-cover-wrap">
          <img class="article-cover" src="<%= post.coverImage %>" alt="<%= post.coverImageAlt || post.title %>" width="720" height="300" />
        </div>
      <% } %>

      <% if (post.videoEmbedUrl) { %>
        <div class="article-cover-wrap">
          <iframe class="article-cover" style="aspect-ratio:16/9;width:100%;border:0;" src="<%= post.videoEmbedUrl %>" title="Embedded video for <%= post.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
        </div>
      <% } %>

      <main class="article-main">
        <article class="article-prose">
          <%- post.contentHtml %>

          <%- include('partials/registry-newsletter', {
            newsletterVariant: 'inline',
            newsletterSource: 'blog_post_cta',
            newsletterId: 'articleNewsletter',
          }) %>

          <div class="article-author">
            <span class="article-author__avatar" aria-hidden="true">RM</span>
            <div>
              <div class="article-author__name">Written by Rasmus Mencke</div>
              <div class="article-author__bio">Technology and product leader sharing practical insights on AI, leadership, and scaling teams.</div>
            </div>
          </div>

          <section class="article-feedback feedback-section" data-slug="<%= post.slug %>" aria-label="Article feedback">
            <span class="article-feedback__label">Was this useful?</span>
            <button type="button" class="article-vote reaction-btn" data-reaction="up" aria-pressed="false">
              👍 <span class="reaction-count" data-count="up">0</span>
            </button>
            <button type="button" class="article-vote reaction-btn" data-reaction="down" aria-pressed="false">
              👎 <span class="reaction-count" data-count="down">0</span>
            </button>
          </section>

          <section class="article-comments" aria-label="Comments">
            <h3>Leave a comment</h3>
            <form id="commentForm" novalidate>
              <input type="text" name="name" id="commentName" placeholder="Your name" maxlength="60" required />
              <textarea name="comment" id="commentBody" placeholder="Share your take, question, or feedback..." maxlength="1000" required></textarea>
              <input class="home-nl__hp" type="text" name="website" id="commentWebsite" autocomplete="off" tabindex="-1" aria-hidden="true" />
              <% if (turnstileSiteKey) { %>
                <div style="margin-bottom:10px;">
                  <div id="commentTurnstile" class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="light"></div>
                </div>
              <% } %>
              <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <span id="commentStatus" role="status" aria-live="polite" style="font-size:13px;color:var(--hp-muted2);"></span>
                <button type="submit" class="mcp-btn-primary" id="commentSubmit" style="margin-left:auto;">Post comment</button>
              </div>
            </form>
            <div id="commentList" style="margin-top:20px;">
              <p id="commentsEmpty" style="font-size:14px;color:var(--hp-muted2);">Be the first to share your thoughts.</p>
            </div>
          </section>
        </article>

        <% if (toc && toc.length) { %>
          <aside class="article-toc" aria-label="Table of contents">
            <div class="article-toc__sticky">
              <div class="article-toc__label">On this page</div>
              <div class="article-toc__list">
                <% toc.forEach(function(item) { %>
                  <a href="<%= item.href %>"><%= item.label %></a>
                <% }); %>
              </div>
            </div>
          </aside>
        <% } %>
      </main>

      <% if (relatedPosts && relatedPosts.length) { %>
        <section class="article-related" aria-label="Related insights">
          <div class="article-related__inner">
            <h2>Related insights</h2>
            <div class="article-related__grid">
              <% relatedPosts.forEach(function(relatedPost) { %>
                <a class="article-related-card" href="/insights/<%= relatedPost.slug %>">
                  <div class="article-related-card__date"><%= relatedPost.date %></div>
                  <div class="article-related-card__title"><%= relatedPost.title %></div>
                  <div class="article-related-card__excerpt"><%= relatedPost.excerpt %></div>
                </a>
              <% }); %>
            </div>
          </div>
        </section>
      <% } %>
    <% } %>

    <%- include('partials/registry-footer') %>

    <script src="/js/registry.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/home-newsletter.js?v=<%= assetVersion %>" defer></script>
    <% if (post) { %>
      <script src="/js/article-page.js?v=<%= assetVersion %>" defer></script>
      <script>
        window.__ARTICLE_FEEDBACK__ = {
          slug: <%- JSON.stringify(post.slug) %>,
          hasTurnstile: <%- JSON.stringify(Boolean(turnstileSiteKey)) %>,
        };
      </script>
      <script src="/js/article-feedback.js?v=<%= assetVersion %>" defer></script>
    <% } %>
  </body>
</html>
