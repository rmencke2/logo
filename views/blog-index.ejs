<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>Insights - Influzer.ai</title>
    <meta name="description" content="Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive." />
    <link rel="canonical" href="https://www.influzer.ai/insights" />
    <%- include('partials/seo-social', {
      ogTitle: 'Insights - Influzer.ai',
      ogDescription: 'Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive.',
      ogUrl: 'https://www.influzer.ai/insights',
      ogImage: featuredPost && featuredPost.coverImage ? `https://www.influzer.ai${featuredPost.coverImage}` : undefined,
      ogType: 'website',
    }) %>
    <%- include('partials/favicon-links') %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/home.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/insights-index.css?v=<%= assetVersion %>" />
    <script type="application/ld+json">
      <%- JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Blog',
        name: 'Influzer.ai Insights',
        description: 'Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive.',
        url: 'https://www.influzer.ai/insights',
      }) %>
    </script>
  </head>
  <body class="registry-page">
    <%- include('partials/home-header') %>

    <header class="insights-hero">
      <div class="insights-hero__inner">
        <p class="insights-hero__eyebrow">Original writing</p>
        <h1 class="insights-hero__title">Insights</h1>
        <p class="insights-hero__standfirst">
          Thoughts on AI, leadership, scaling teams, and building product-led companies — written by Influzer, not aggregated.
        </p>
      </div>
    </header>

    <main class="insights-shell" id="main">
      <div class="insights-pills" id="insightsFilters" role="group" aria-label="Filter by topic">
        <% const filterCats = typeof filterCategories !== 'undefined' ? filterCategories : ['AI', 'Growth', 'Leadership']; %>
        <button type="button" class="insights-pill is-active" data-cat="All">All</button>
        <% filterCats.forEach(function(cat) { %>
          <button type="button" class="insights-pill" data-cat="<%= cat %>"><%= cat %></button>
        <% }); %>
      </div>

      <% if (featuredPost) { %>
        <a class="insights-featured" href="/insights/<%= featuredPost.slug %>">
          <div class="insights-featured__cover">
            <% if (featuredPost.coverImage) { %>
              <img src="<%= featuredPost.coverImage %>" alt="<%= featuredPost.coverImageAlt || '' %>" loading="lazy" />
            <% } else { %>
              <span class="insights-featured__cover-label">featured cover image</span>
            <% } %>
          </div>
          <div class="insights-featured__body">
            <div class="insights-featured__badge">FEATURED INSIGHT</div>
            <h2 class="insights-featured__title"><%= featuredPost.title %></h2>
            <p class="insights-featured__excerpt"><%= featuredPost.excerpt %></p>
            <span class="insights-featured__cta">Read article →</span>
          </div>
        </a>
      <% } %>

      <% const gridPosts = (posts || []).filter(function(p) { return !featuredPost || p.slug !== featuredPost.slug; }); %>
      <div class="insights-grid" id="insightsGrid">
        <% if (!gridPosts.length) { %>
          <div class="insights-empty">No articles yet.</div>
        <% } else { %>
          <% gridPosts.forEach(function(post) { %>
            <%
              const tagList = (post.tags || []).slice(0, 3);
              const cats = [];
              (post.tags || []).forEach(function(t) {
                const key = String(t);
                if (/^ai$/i.test(key) || /ai\b/i.test(key)) cats.push('AI');
                if (/growth/i.test(key) || /roi|saas|ebitda|margin/i.test(key)) cats.push('Growth');
                if (/leadership|governance|execution|operating/i.test(key)) cats.push('Leadership');
              });
              const uniqueCats = [...new Set(cats)];
            %>
            <a
              class="insights-card"
              href="/insights/<%= post.slug %>"
              data-cats="<%= uniqueCats.join(',') %>"
            >
              <div class="insights-card__cover">
                <% if (post.coverImage) { %>
                  <img src="<%= post.coverImage %>" alt="<%= post.coverImageAlt || '' %>" loading="lazy" />
                <% } %>
              </div>
              <div class="insights-card__body">
                <div class="insights-card__date"><%= post.date %></div>
                <h2 class="insights-card__title"><%= post.title %></h2>
                <p class="insights-card__excerpt"><%= post.excerpt %></p>
                <% if (tagList.length) { %>
                  <div class="insights-card__tags">
                    <% tagList.forEach(function(tag) { %>
                      <span class="insights-card__tag"><%= tag %></span>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            </a>
          <% }); %>
        <% } %>
        <div class="insights-empty" id="insightsEmpty" hidden>No articles in this category.</div>
      </div>

      <%- include('partials/registry-newsletter', {
        newsletterVariant: 'band',
        newsletterSource: 'insights_index',
        newsletterId: 'newsletter',
        newsletterEyebrow: 'ONE EMAIL PER WEEK',
        newsletterTitle: 'Get weekly executive AI insights',
        newsletterDesc: 'Practical frameworks you can apply immediately. Join 4,200+ leaders.',
        newsletterSuccess: "✓ You're in — first email this week.",
      }) %>
    </main>

    <%- include('partials/registry-footer') %>

    <script src="/js/registry.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/home-newsletter.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/insights-index.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
