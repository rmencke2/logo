<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>Insights - Influzer.ai</title>
    <meta name="description" content="Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive." />
    <link rel="canonical" href="<%= selectedCategory ? `https://www.influzer.ai/insights?category=${encodeURIComponent(selectedCategory)}` : 'https://www.influzer.ai/insights' %>" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Influzer.ai" />
    <meta property="og:title" content="Insights - Influzer.ai" />
    <meta property="og:description" content="Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive." />
    <meta property="og:url" content="<%= selectedCategory ? `https://www.influzer.ai/insights?category=${encodeURIComponent(selectedCategory)}` : 'https://www.influzer.ai/insights' %>" />
    <% if (featuredPost && featuredPost.coverImage) { %>
      <meta property="og:image" content="https://www.influzer.ai<%= featuredPost.coverImage %>" />
    <% } %>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Insights - Influzer.ai" />
    <meta name="twitter:description" content="Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive." />
    <% if (featuredPost && featuredPost.coverImage) { %>
      <meta name="twitter:image" content="https://www.influzer.ai<%= featuredPost.coverImage %>" />
    <% } %>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css">
    <script type="application/ld+json">
      <%- JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Blog',
        name: 'Influzer.ai Insights',
        description:
          'Insights on AI, leadership, product strategy, and scaling teams from an experienced technology executive.',
        url: selectedCategory
          ? `https://www.influzer.ai/insights?category=${encodeURIComponent(selectedCategory)}`
          : 'https://www.influzer.ai/insights',
      }) %>
    </script>
    <style>
      .insights-page { max-width: 1120px; margin: 0 auto; padding: 48px 20px 80px; }
      .insights-header { margin-bottom: 24px; }
      .insights-header p { max-width: 760px; }
      .category-filter { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
      .category-chip { text-decoration: none; font-family: var(--font-ui); font-size: .8rem; padding: 7px 12px; border-radius: 999px; border: 1px solid var(--color-border); color: var(--color-charcoal); background: var(--color-paper); }
      .category-chip.active { background: var(--color-charcoal); color: #fff; border-color: var(--color-charcoal); }
      .featured-card { display: grid; grid-template-columns: 1.15fr 1fr; gap: 0; border: 1px solid var(--color-border); background: var(--color-paper); border-radius: 18px; overflow: hidden; margin-bottom: 24px; text-decoration: none; color: inherit; }
      .featured-media { min-height: 260px; background: var(--color-cream-dark); }
      .featured-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .featured-content { padding: 28px; display: flex; flex-direction: column; justify-content: center; }
      .featured-label { font-family: var(--font-ui); letter-spacing: .08em; font-size: .72rem; text-transform: uppercase; color: var(--color-muted); margin-bottom: 10px; }
      .featured-title { font-family: var(--font-display); font-size: 2rem; line-height: 1.15; margin-bottom: 10px; }
      .featured-excerpt { color: var(--color-charcoal-light); margin-bottom: 14px; }
      .featured-cta { font-family: var(--font-ui); font-weight: 600; }
      .insights-grid { display: grid; gap: 20px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
      .insight-card { background: var(--color-paper); border: 1px solid var(--color-border); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: transform .2s ease, box-shadow .2s ease; }
      .insight-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-medium); }
      .insight-cover { width: 100%; height: 180px; object-fit: cover; background: var(--color-cream-dark); }
      .insight-content { padding: 20px; }
      .insight-meta { font-family: var(--font-ui); font-size: .8rem; color: var(--color-muted); margin-bottom: 8px; }
      .insight-title { font-family: var(--font-display); font-size: 1.35rem; margin-bottom: 8px; }
      .insight-excerpt { font-size: .98rem; color: var(--color-charcoal-light); }
      .insight-tags { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; }
      .insight-tag { font-family: var(--font-ui); font-size: .75rem; padding: 4px 8px; border-radius: 999px; background: var(--color-terracotta-light); color: var(--color-charcoal); }
      .empty-state { background: var(--color-paper); border: 1px dashed var(--color-border-strong); border-radius: 16px; padding: 24px; }
      .newsletter-card { margin-top: 24px; border: 1px solid var(--color-border); border-radius: 16px; background: var(--color-cream-dark); padding: 18px; }
      .newsletter-card h2 { margin: 0 0 8px 0; font-size: 1.4rem; }
      .newsletter-card p { margin: 0 0 10px 0; color: var(--color-charcoal-light); }
      .newsletter-form { display: grid; gap: 8px; }
      .newsletter-row { display: flex; gap: 8px; flex-wrap: wrap; }
      .newsletter-input { flex: 1; min-width: 220px; border: 1px solid var(--color-border); border-radius: 999px; padding: 10px 14px; font: inherit; }
      .newsletter-submit { border: 0; border-radius: 999px; background: var(--color-charcoal); color: #fff; padding: 10px 14px; font-family: var(--font-ui); font-weight: 600; cursor: pointer; }
      .newsletter-submit:disabled { opacity: .65; cursor: not-allowed; }
      .newsletter-hp { display: none !important; }
      .newsletter-status { font-family: var(--font-ui); font-size: .84rem; min-height: 1.1em; color: var(--color-muted); }
      .newsletter-status.error { color: #b3261e; }
      .newsletter-status.success { color: #0f6f4f; }
      @media (max-width: 900px) {
        .featured-card { grid-template-columns: 1fr; }
        .featured-title { font-size: 1.65rem; }
      }
    </style>
  </head>
  <body>
    <div class="auth-header" id="siteHeader">
      <div class="auth-header-start">
        <button type="button" class="nav-menu-toggle" id="navMenuToggle" aria-expanded="false" aria-controls="mainSiteNav" aria-label="Open menu">
          <span class="nav-menu-toggle-bars" aria-hidden="true">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
          </span>
        </button>
        <a href="/">Influzer.ai</a>
        <nav id="mainSiteNav" class="site-nav" aria-label="Main">
          <a href="/insights">Insights</a>
          <a href="/">Logo Generator</a>
          <a href="/video-converter">AVI to MP4</a>
          <a href="/video-to-gif">Video to GIF</a>
        </nav>
      </div>
    </div>

    <main class="insights-page">
      <header class="insights-header">
        <h1>Insights</h1>
        <p class="subtitle">Thoughts on AI, leadership, scaling teams, and building product-led companies.</p>
      </header>
      <% if (categories && categories.length) { %>
        <nav class="category-filter" aria-label="Insight categories">
          <a href="/insights" class="category-chip <%= selectedCategory ? '' : 'active' %>">All</a>
          <% categories.forEach((category) => { %>
            <a href="/insights?category=<%= encodeURIComponent(category) %>" class="category-chip <%= selectedCategory === category ? 'active' : '' %>"><%= category %></a>
          <% }) %>
        </nav>
      <% } %>

      <% if (!posts || posts.length === 0) { %>
        <section class="empty-state">
          <h2 style="margin-bottom: 8px;">No posts published yet</h2>
          <p>Add a JSON file in <code>content/blog/</code> to publish your first insight.</p>
        </section>
      <% } else { %>
        <% if (featuredPost) { %>
          <a class="featured-card" href="/insights/<%= featuredPost.slug %>">
            <div class="featured-media">
              <% if (featuredPost.coverImage) { %>
                <img src="<%= featuredPost.coverImage %>" alt="<%= featuredPost.coverImageAlt %>" />
              <% } %>
            </div>
            <div class="featured-content">
              <div class="featured-label">Featured insight</div>
              <h2 class="featured-title"><%= featuredPost.title %></h2>
              <p class="featured-excerpt"><%= featuredPost.excerpt %></p>
              <span class="featured-cta">Read article →</span>
            </div>
          </a>
        <% } %>
        <section class="insights-grid">
          <% posts.forEach((post) => { %>
            <% if (!(featuredPost && post.slug === featuredPost.slug)) { %>
              <a class="insight-card" href="/insights/<%= post.slug %>">
                <% if (post.coverImage) { %>
                  <img class="insight-cover" src="<%= post.coverImage %>" alt="<%= post.coverImageAlt %>" loading="lazy" />
                <% } %>
                <div class="insight-content">
                  <div class="insight-meta"><%= post.date %></div>
                  <h2 class="insight-title"><%= post.title %></h2>
                  <p class="insight-excerpt"><%= post.excerpt %></p>
                  <% if (post.tags && post.tags.length) { %>
                    <div class="insight-tags">
                      <% post.tags.forEach((tag) => { %>
                        <span class="insight-tag"><%= tag %></span>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              </a>
            <% } %>
          <% }) %>
        </section>
        <section class="newsletter-card" aria-label="Subscribe to the newsletter">
          <h2>Get weekly executive AI insights</h2>
          <p>One practical email per week with frameworks you can apply immediately.</p>
          <form class="newsletter-form" id="newsletterForm" novalidate>
            <div class="newsletter-row">
              <input class="newsletter-input" type="email" id="newsletterEmail" placeholder="Enter your email" maxlength="254" required />
              <button class="newsletter-submit" id="newsletterSubmit" type="submit">Subscribe</button>
            </div>
            <input class="newsletter-hp" type="text" id="newsletterWebsite" autocomplete="off" tabindex="-1" aria-hidden="true" />
            <span class="newsletter-status" id="newsletterStatus" role="status" aria-live="polite"></span>
          </form>
        </section>
      <% } %>
    </main>
    <script>
      (function () {
        const form = document.getElementById('newsletterForm');
        const emailEl = document.getElementById('newsletterEmail');
        const submitEl = document.getElementById('newsletterSubmit');
        const statusEl = document.getElementById('newsletterStatus');
        const hpEl = document.getElementById('newsletterWebsite');
        if (!form || !emailEl || !submitEl || !statusEl || !hpEl) return;

        function setStatus(message, type) {
          statusEl.textContent = message || '';
          statusEl.classList.remove('error', 'success');
          if (type) statusEl.classList.add(type);
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const email = String(emailEl.value || '').trim();
          const website = String(hpEl.value || '').trim();
          if (!email) {
            setStatus('Please enter your email address.', 'error');
            return;
          }
          submitEl.disabled = true;
          setStatus('Subscribing...', '');
          try {
            const response = await fetch('/api/newsletter/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ email, source: 'insights_index', website }),
            });
            const data = await response.json();
            if (!response.ok) {
              setStatus(data?.error || 'Could not subscribe right now.', 'error');
            } else {
              setStatus(data?.message || 'Thanks! You are subscribed.', 'success');
              form.reset();
            }
          } catch {
            setStatus('Network error. Please try again.', 'error');
          } finally {
            submitEl.disabled = false;
          }
        });
      })();
    </script>

    <script>
      (function () {
        const siteHeader = document.getElementById('siteHeader');
        const navMenuToggle = document.getElementById('navMenuToggle');
        const mainSiteNav = document.getElementById('mainSiteNav');
        if (!siteHeader || !navMenuToggle || !mainSiteNav) return;

        function closeMobileNav() {
          siteHeader.classList.remove('nav-open');
          navMenuToggle.setAttribute('aria-expanded', 'false');
          navMenuToggle.setAttribute('aria-label', 'Open menu');
        }

        navMenuToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = !siteHeader.classList.contains('nav-open');
          siteHeader.classList.toggle('nav-open', open);
          navMenuToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          navMenuToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        });

        mainSiteNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMobileNav));
        document.addEventListener('click', (e) => {
          if (siteHeader.classList.contains('nav-open') && !siteHeader.contains(e.target)) {
            closeMobileNav();
          }
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && siteHeader.classList.contains('nav-open')) closeMobileNav();
        });
      })();
    </script>
  </body>
</html>
