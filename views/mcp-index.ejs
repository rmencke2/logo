<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>MCP Server Directory - Influzer.ai</title>
    <meta name="description" content="Search and discover Model Context Protocol (MCP) servers and the tools they expose for AI development workflows." />
    <link rel="canonical" href="https://www.influzer.ai/mcp" />
    <meta property="og:title" content="MCP Server Directory - Influzer.ai" />
    <meta property="og:description" content="Browse MCP servers, categories, and tools for developers." />
    <meta property="og:url" content="https://www.influzer.ai/mcp" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
    <style>
      /* Scoped overrides — global button/input rules are form-sized and full-width */
      .mcp-page { max-width: 1120px; margin: 0 auto; padding: 48px 20px 80px; }
      .mcp-page button { width: auto; margin-top: 0; }
      .mcp-page input[type='search'],
      .mcp-page select {
        width: auto;
        margin-top: 0;
        font-family: var(--font-body);
      }

      .mcp-header { margin-bottom: 28px; }
      .mcp-header .mcp-kicker {
        font-family: var(--font-ui);
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--color-terracotta);
        margin: 0 0 10px 0;
      }
      .mcp-header h1 { margin: 0 0 12px 0; }
      .mcp-header .mcp-lead { max-width: 720px; margin: 0; color: var(--color-charcoal-light); font-size: 1.08rem; line-height: 1.65; }

      .mcp-controls {
        background: var(--color-paper);
        border: 1px solid var(--color-border);
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 28px;
        box-shadow: 0 2px 14px rgba(45, 42, 38, 0.04);
      }
      .mcp-controls-top {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        margin-bottom: 16px;
      }
      .mcp-search-wrap { flex: 1; min-width: min(100%, 280px); position: relative; }
      .mcp-search-wrap input[type='search'] {
        width: 100%;
        padding: 12px 16px 12px 42px;
        font-size: 1rem;
        background: var(--color-cream);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-charcoal);
      }
      .mcp-search-wrap input[type='search']:focus {
        outline: none;
        border-color: var(--color-terracotta);
        background: var(--color-paper);
        box-shadow: 0 0 0 3px var(--color-terracotta-light);
      }
      .mcp-search-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
        color: var(--color-muted);
        pointer-events: none;
      }
      .mcp-sort-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
      }
      .mcp-sort-wrap label {
        font-family: var(--font-ui);
        font-size: .85rem;
        color: var(--color-muted);
        white-space: nowrap;
      }
      .mcp-sort-wrap select {
        padding: 10px 32px 10px 12px;
        font-size: .9rem;
        background: var(--color-cream);
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-charcoal);
        cursor: pointer;
      }

      .mcp-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .mcp-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid var(--color-border);
        background: var(--color-cream);
        color: var(--color-charcoal);
        font-family: var(--font-ui);
        font-size: .8rem;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s ease, border-color .15s ease, color .15s ease;
      }
      .mcp-chip:hover {
        border-color: var(--color-border-strong);
        background: var(--color-cream-dark);
      }
      .mcp-chip.active {
        background: var(--color-charcoal);
        border-color: var(--color-charcoal);
        color: #fff;
      }
      .mcp-chip-count {
        font-size: .72rem;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 999px;
        background: rgba(45, 42, 38, 0.08);
        color: var(--color-charcoal-light);
      }
      .mcp-chip.active .mcp-chip-count {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
      }

      .mcp-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
      }
      .mcp-count {
        font-family: var(--font-ui);
        font-size: .88rem;
        color: var(--color-muted);
        margin: 0;
      }
      .mcp-clear-link {
        font-family: var(--font-ui);
        font-size: .85rem;
        color: var(--color-terracotta);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        text-decoration: underline;
        font-weight: 500;
      }
      .mcp-clear-link:hover { color: var(--color-terracotta-hover); background: transparent; transform: none; }

      .mcp-grid {
        display: grid;
        gap: 20px;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      }
      .mcp-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: var(--color-charcoal);
        background: var(--color-paper);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
      }
      .mcp-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-border-strong);
      }
      .mcp-card-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
      .mcp-card-head { display: flex; gap: 14px; margin-bottom: 14px; }
      .mcp-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
        background: var(--color-cream-dark);
        border: 1px solid var(--color-border);
      }
      .mcp-card-title {
        font-family: var(--font-display);
        font-size: 1.3rem;
        line-height: 1.2;
        margin: 0 0 8px 0;
        color: var(--color-ink);
      }
      .mcp-badges { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
      .mcp-badge {
        font-family: var(--font-ui);
        font-size: .72rem;
        padding: 3px 9px;
        border-radius: 999px;
        background: var(--color-cream-dark);
        color: var(--color-charcoal-light);
      }
      .mcp-badge-official {
        background: var(--color-terracotta-light);
        color: var(--color-charcoal);
        font-weight: 600;
      }
      .mcp-card-desc {
        font-size: .96rem;
        color: var(--color-charcoal-light);
        line-height: 1.6;
        flex: 1;
        margin: 0 0 14px 0;
      }
      .mcp-tools {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding-top: 14px;
        border-top: 1px solid var(--color-border);
      }
      .mcp-tool-pill {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: .68rem;
        padding: 4px 8px;
        border-radius: 6px;
        background: var(--color-cream);
        color: var(--color-charcoal);
        border: 1px solid var(--color-border);
      }
      .mcp-tool-pill.muted { opacity: .75; border-style: dashed; }

      .mcp-empty {
        text-align: center;
        padding: 48px 24px;
        background: var(--color-paper);
        border: 1px dashed var(--color-border-strong);
        border-radius: 16px;
      }
      .mcp-empty p { margin: 0 0 12px 0; color: var(--color-charcoal-light); }

      @media (max-width: 640px) {
        .mcp-controls-top { flex-direction: column; align-items: stretch; }
        .mcp-sort-wrap { justify-content: space-between; }
        .mcp-sort-wrap select { flex: 1; }
      }
    </style>
  </head>
  <body>
    <div class="auth-header" id="siteHeader">
      <div class="auth-header-start">
        <button type="button" class="nav-menu-toggle" id="navMenuToggle" aria-expanded="false" aria-controls="mainSiteNav" aria-label="Open menu">
          <span class="nav-menu-toggle-bars" aria-hidden="true">
            <span class="nav-toggle-bar"></span><span class="nav-toggle-bar"></span><span class="nav-toggle-bar"></span>
          </span>
        </button>
        <a href="/">Influzer.ai</a>
        <nav id="mainSiteNav" class="site-nav" aria-label="Main">
          <%- include('partials/site-nav-insights-mcp') %>
          <a href="/">Logo Generator</a>
        </nav>
      </div>
    </div>

    <main class="mcp-page">
      <header class="mcp-header">
        <p class="mcp-kicker">Model Context Protocol</p>
        <h1>MCP Server Directory</h1>
        <p class="mcp-lead">Search and discover MCP servers and the tools they expose for AI-assisted development.</p>
      </header>

      <section class="mcp-controls" aria-label="Search and filters">
        <div class="mcp-controls-top">
          <div class="mcp-search-wrap">
            <span class="mcp-search-icon" aria-hidden="true">⌕</span>
            <input type="search" id="mcpSearch" placeholder="Search servers, tools, categories…" aria-label="Search MCP servers" autocomplete="off" />
          </div>
          <div class="mcp-sort-wrap">
            <label for="mcpSort">Sort by</label>
            <select id="mcpSort">
              <option value="name">Name A–Z</option>
              <option value="tools">Most tools</option>
              <option value="official">Official first</option>
            </select>
          </div>
        </div>
        <div class="mcp-filters" id="mcpFilters" role="group" aria-label="Filter by category"></div>
      </section>

      <div class="mcp-meta">
        <p class="mcp-count" id="mcpCount" aria-live="polite"></p>
        <button type="button" class="mcp-clear-link" id="mcpClear" hidden>Clear filters</button>
      </div>

      <div class="mcp-grid" id="mcpGrid"></div>
      <div class="mcp-empty" id="mcpEmpty" hidden>
        <p>No servers match your search or filters.</p>
        <button type="button" class="mcp-clear-link" id="mcpClearEmpty">Clear filters</button>
      </div>
    </main>

    <script type="application/json" id="mcpData"><%- JSON.stringify({ categories, servers }) %></script>
    <script>
      (function () {
        const data = JSON.parse(document.getElementById('mcpData').textContent);
        const servers = data.servers;
        const categories = ['All', ...data.categories];
        const grid = document.getElementById('mcpGrid');
        const countEl = document.getElementById('mcpCount');
        const emptyEl = document.getElementById('mcpEmpty');
        const filtersEl = document.getElementById('mcpFilters');
        const clearBtn = document.getElementById('mcpClear');
        const clearEmptyBtn = document.getElementById('mcpClearEmpty');
        let query = '';
        let category = 'All';
        let sort = 'name';

        function esc(s) {
          return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function counts() {
          const c = {};
          for (const cat of data.categories) {
            c[cat] = servers.filter((s) => s.category === cat).length;
          }
          return c;
        }
        const catCounts = counts();

        categories.forEach((cat) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          const n = cat === 'All' ? servers.length : catCounts[cat] || 0;
          btn.className = 'mcp-chip' + (cat === 'All' ? ' active' : '');
          btn.dataset.category = cat;
          btn.innerHTML =
            '<span>' + esc(cat) + '</span><span class="mcp-chip-count">' + n + '</span>';
          btn.addEventListener('click', () => {
            category = cat;
            filtersEl.querySelectorAll('.mcp-chip').forEach((b) =>
              b.classList.toggle('active', b.dataset.category === cat),
            );
            render();
          });
          filtersEl.appendChild(btn);
        });

        function matches(s) {
          const q = query.trim().toLowerCase();
          if (category !== 'All' && s.category !== category) return false;
          if (!q) return true;
          if (s.name.toLowerCase().includes(q)) return true;
          if (s.description.toLowerCase().includes(q)) return true;
          if (s.category.toLowerCase().includes(q)) return true;
          return s.tools.some(
            (t) =>
              t.name.toLowerCase().includes(q) || t.description.toLowerCase().includes(q),
          );
        }

        function sortList(list) {
          const copy = [...list];
          if (sort === 'tools') return copy.sort((a, b) => b.tools.length - a.tools.length);
          if (sort === 'official') {
            return copy.sort((a, b) => {
              if (a.official !== b.official) return a.official ? -1 : 1;
              return a.name.localeCompare(b.name);
            });
          }
          return copy.sort((a, b) => a.name.localeCompare(b.name));
        }

        function hasActiveFilters() {
          return query.trim() !== '' || category !== 'All';
        }

        function clearFilters() {
          query = '';
          category = 'All';
          document.getElementById('mcpSearch').value = '';
          filtersEl.querySelectorAll('.mcp-chip').forEach((b) =>
            b.classList.toggle('active', b.dataset.category === 'All'),
          );
          render();
        }

        function render() {
          const list = sortList(servers.filter(matches));
          const filtered = hasActiveFilters();
          countEl.textContent =
            'Showing ' + list.length + (list.length === 1 ? ' server' : ' servers');
          clearBtn.hidden = !filtered;
          emptyEl.hidden = list.length > 0;
          grid.hidden = list.length === 0;

          grid.innerHTML = list
            .map((s) => {
              const tools = s.tools.slice(0, 3);
              const extra = s.tools.length - tools.length;
              const toolHtml =
                tools
                  .map((t) => '<span class="mcp-tool-pill">' + esc(t.name) + '</span>')
                  .join('') +
                (extra > 0
                  ? '<span class="mcp-tool-pill muted">+' + extra + ' more</span>'
                  : '');
              const official = s.official
                ? '<span class="mcp-badge mcp-badge-official">Official</span>'
                : '';
              return (
                '<a class="mcp-card" href="/mcp/' +
                esc(s.slug) +
                '">' +
                '<div class="mcp-card-body">' +
                '<div class="mcp-card-head">' +
                '<div class="mcp-icon" aria-hidden="true">' +
                s.iconEmoji +
                '</div>' +
                '<div>' +
                '<h2 class="mcp-card-title">' +
                esc(s.name) +
                '</h2>' +
                '<div class="mcp-badges"><span class="mcp-badge">' +
                esc(s.category) +
                '</span>' +
                official +
                '</div></div></div>' +
                '<p class="mcp-card-desc">' +
                esc(s.description) +
                '</p>' +
                '<div class="mcp-tools">' +
                toolHtml +
                '</div></div></a>'
              );
            })
            .join('');
        }

        document.getElementById('mcpSearch').addEventListener('input', (e) => {
          query = e.target.value;
          render();
        });
        document.getElementById('mcpSort').addEventListener('change', (e) => {
          sort = e.target.value;
          render();
        });
        clearBtn.addEventListener('click', clearFilters);
        clearEmptyBtn.addEventListener('click', clearFilters);
        render();
      })();
    </script>
    <script>
      (function () {
        const h = document.getElementById('siteHeader');
        const t = document.getElementById('navMenuToggle');
        const n = document.getElementById('mainSiteNav');
        if (!h || !t || !n) return;
        t.addEventListener('click', (e) => {
          e.stopPropagation();
          const open = !h.classList.contains('nav-open');
          h.classList.toggle('nav-open', open);
          t.setAttribute('aria-expanded', open);
        });
        n.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => h.classList.remove('nav-open'));
      })();
    </script>
  </body>
</html>
