<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title><%= pageTitle %> - Influzer.ai</title>
    <meta name="description" content="<%= metaDescription %>" />
    <link rel="canonical" href="<%= canonicalUrl %>" />
    <%- include('partials/seo-social', {
      ogTitle: pageTitle + ' - Influzer.ai',
      ogDescription: metaDescription,
      ogUrl: canonicalUrl,
      ogImage: typeof ogImage !== 'undefined' ? ogImage : undefined,
    }) %>
    <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
      <script type="application/ld+json">
        <%- JSON.stringify(jsonLd) %>
      </script>
    <% } %>
    <%- include('partials/favicon-links') %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/home.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/mcp-directory-page.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/seo-content.css?v=<%= assetVersion %>" />
  </head>
  <body class="registry-page">
    <%- include('partials/home-header') %>

    <header class="dir-hero">
      <div class="dir-hero__inner">
        <p class="dir-hero__eyebrow">Model Context Protocol</p>
        <h1 class="dir-hero__title"><%= catalogScope === 'top' ? 'Top 100 MCP Servers' : 'Full MCP Server Directory' %></h1>
        <% if (typeof heroStats !== 'undefined' && heroStats) { %>
          <p class="dir-hero__lead">
            <% if (catalogScope === 'top') { %>
              Curated leaders with indexed tools, transport, and setup steps.
              <b><%= totalCatalog.toLocaleString() %></b> servers in the full registry ·
              <b><%= (typeof totalWithTools !== 'undefined' ? totalWithTools : heroStats.serversWithIndexedTools).toLocaleString() %></b> with searchable tools.
            <% } else { %>
              Search the full registry — connect URLs, tool indexes, and setup steps.
              <b><%= totalCatalog.toLocaleString() %></b> servers ·
              <b><%= (typeof totalWithTools !== 'undefined' ? totalWithTools : heroStats.serversWithIndexedTools).toLocaleString() %></b> with searchable tools.
            <% } %>
          </p>
          <div class="dir-hero__stats" aria-label="Directory stats">
            <span><b><%= totalCatalog.toLocaleString() %></b> servers</span>
            <span aria-hidden="true">·</span>
            <span><b><%= heroStats.totalTools.toLocaleString() %></b> tools indexed</span>
            <span aria-hidden="true">·</span>
            <span><b><%= heroStats.categoryCount %></b> categories</span>
          </div>
        <% } %>
      </div>
    </header>

    <main class="dir-shell" id="main">
      <% if (typeof featuredPromo !== 'undefined' && featuredPromo) { %>
        <aside class="dir-featured" aria-label="Featured server">
          <div class="dir-featured__icon" aria-hidden="true"><%= (featuredPromo.provider || 'W').charAt(0) %></div>
          <div class="dir-featured__body">
            <div class="dir-featured__name-row">
              <span class="dir-featured__name"><%= featuredPromo.provider %></span>
              <span class="dir-featured__badge">FEATURED</span>
            </div>
            <p class="dir-featured__desc"><%= featuredPromo.blurb %></p>
          </div>
          <a class="dir-featured__cta" href="<%= featuredPromo.url %>"<%= featuredPromo.external ? ' target="_blank" rel="noopener noreferrer sponsored"' : '' %>><%= featuredPromo.cta %> →</a>
        </aside>
      <% } %>

      <div class="dir-controls">
        <nav class="dir-tabs" aria-label="Directory scope">
          <a href="/mcp" class="<%= catalogScope === 'top' ? 'is-active' : '' %>">Top 100</a>
          <a href="/mcp/all" class="<%= catalogScope === 'all' ? 'is-active' : '' %>">Full directory (<%= totalCatalog.toLocaleString() %>)</a>
        </nav>
        <div class="dir-search">
          <span class="dir-search__glyph" aria-hidden="true">⌕</span>
          <input type="search" id="mcpSearch" placeholder="Search servers or tools…" aria-label="Search MCP servers" autocomplete="off" />
        </div>
        <div class="dir-sort">
          <label class="visually-hidden" for="mcpSort" style="position:absolute;left:-9999px;">Sort</label>
          <select id="mcpSort">
            <option value="stars" selected>Most popular</option>
            <option value="name">Name A–Z</option>
            <option value="tools">Most tools</option>
            <option value="official">Official first</option>
          </select>
        </div>
      </div>

      <div class="dir-pills" id="mcpFilters" role="group" aria-label="Filter by category"></div>

      <% if (catalogScope === 'all') { %>
        <label class="dir-tools-only">
          <input type="checkbox" id="mcpToolsOnly" <%= defaultToolsOnly !== false ? 'checked' : '' %> />
          Only show servers with indexed tools (<%= typeof totalWithTools !== 'undefined' ? totalWithTools.toLocaleString() : '—' %> of <%= totalCatalog.toLocaleString() %>)
        </label>
      <% } %>

      <div class="dir-meta">
        <p class="dir-meta__count" id="mcpCount" aria-live="polite"></p>
        <button type="button" id="mcpClear" hidden>Clear filters</button>
      </div>

      <% if (typeof inlineCatalogJson !== 'undefined' && inlineCatalogJson) { %>
        <script id="mcpCatalogData" type="application/json"><%- inlineCatalogJson %></script>
      <% } %>

      <p class="dir-loading" id="mcpLoading"<%= (typeof previewServers !== 'undefined' && previewServers && previewServers.length) || (typeof inlineCatalogJson !== 'undefined' && inlineCatalogJson) ? ' hidden' : '' %>>Loading MCP server catalog…</p>

      <div
        class="dir-grid"
        id="mcpGrid"
        data-scope="<%= catalogScope %>"
        data-tools-only="<%= defaultToolsOnly !== false ? '1' : '0' %>"
        data-preferred-cats="Dev Tools|Search & Web|Communication|Databases|Data & Analytics"
        hidden
      ></div>

      <button type="button" class="dir-load-more" id="mcpLoadMore" hidden>Show more servers</button>

      <div class="dir-empty" id="mcpEmpty" hidden>
        <p data-empty-tip>No servers match your search or filters.</p>
        <button type="button" id="mcpClearEmpty" style="margin-top:12px;background:none;border:none;color:var(--hp-link);font-family:var(--hp-font);font-weight:600;cursor:pointer;">Clear filters</button>
      </div>

      <div class="dir-bottom">
        <% if (catalogScope === 'top') { %>
          <a class="dir-bottom__cta" href="/mcp/all">Browse all <%= totalCatalog.toLocaleString() %> servers →</a>
        <% } else { %>
          <a class="dir-bottom__cta" href="/mcp">← Back to Top 100</a>
        <% } %>
        <% if (lastUpdated) { %>
          <p class="dir-bottom__note">Data last refreshed <%= lastUpdated %> · tool indexes re-validated daily</p>
        <% } %>
      </div>

      <p style="margin-top:18px;font-size:13px;color:var(--hp-muted2);">
        Know a server we should list?
        <a href="/mcp/submit">Submit an MCP server</a>
        · <a href="/mcp/topics">Topic guides</a>
        · <a href="/mcp/discovery/setup">Our MCP</a>
      </p>

      <% if (typeof seoContent !== 'undefined' && seoContent) { %>
        <div class="dir-seo">
          <%- include('partials/seo-faq-crosslinks', { seoContent: seoContent }) %>
        </div>
      <% } %>
    </main>

    <%- include('partials/registry-footer') %>

    <script src="/js/registry.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/mcp-cards.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/mcp-directory-page.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
