# Copy to .deploy.env and fill in ( .deploy.env is gitignored )
#
#   cp .deploy.env.example .deploy.env

# Lightsail public static IP (Lightsail → your instance → Public IP)
DEPLOY_HOST=18.199.191.173

# SSH user (often bitnami on Bitnami stacks, or ubuntu on plain Ubuntu)
DEPLOY_USER=bitnami

# Path to your Lightsail SSH private key (.pem from Lightsail → Account → SSH keys)
DEPLOY_KEY=$HOME/.ssh/LightsailDefaultKey.pem

# Git clone path on the server
DEPLOY_PATH=/home/bitnami/logo

DEPLOY_BRANCH=main
PM2_APP_NAME=logo-generator

# Optional extra ssh flags (default: BatchMode + ConnectTimeout)
# SSH_OPTS=-o BatchMode=yes -o ConnectTimeout=15
